# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — never commit real credentials.

# --- Redis (Upstash via Vercel Marketplace) ---
# Find these in Vercel: Project -> Storage -> your Redis database -> .env.local tab
# (Vercel may label them UPSTASH_REDIS_REST_URL/TOKEN or KV_REST_API_URL/TOKEN
#  depending on when the integration was created — this app accepts either.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Dashboard password (custom, since Hobby plan has no native password protection) ---
DASHBOARD_PASSWORD=
